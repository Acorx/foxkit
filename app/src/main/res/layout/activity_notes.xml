<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical" android:padding="16dp">
    <TextView android:id="@+id/ion_1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="18sp" android:padding="8dp" />

    <EditText android:id="@+id/ion_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Write a note..."
        android:layout_marginTop="8dp" />

    <Button android:id="@+id/ion_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save"
        android:layout_marginTop="4dp" />

    <Button android:id="@+id/ion_4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Share"
        android:layout_marginTop="4dp" />

    <Button android:id="@+id/ion_5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Back"
        android:layout_marginTop="4dp" />

</LinearLayout>
